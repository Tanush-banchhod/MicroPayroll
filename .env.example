# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=micropayroll
POSTGRES_PASSWORD=micropayroll
POSTGRES_DB=micropayroll
DATABASE_URL=postgresql+asyncpg://micropayroll:micropayroll@localhost:5432/micropayroll

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change_me_secret
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── App Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change_me_very_secret_key_at_least_32_chars

# ── Face Recognition ──────────────────────────────────────────────────────────
FACE_MATCH_THRESHOLD=0.6
SHIFT_START_WINDOW_HOURS=2
STANDARD_SHIFT_HOURS=8

# ── Email (optional) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
TEMP_IMAGE_DIR=/tmp/micropayroll
